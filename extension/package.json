{
  "name": "silo-local-ai",
  "displayName": "Silo — Local & Cloud AI Coding Assistant",
  "description": "Agentic coding assistant for VS Code. Local Ollama or OpenAI / Anthropic / Gemini. Modes, tools, memory, slash commands.",
  "version": "1.2.0",
  "publisher": "danielmadridg",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/danielmadridg/silo" },
  "bugs": { "url": "https://github.com/danielmadridg/silo/issues" },
  "homepage": "https://github.com/danielmadridg/silo#readme",
  "icon": "silologo.png",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["AI", "Chat", "Programming Languages", "Other"],
  "keywords": [
    "ai",
    "chat",
    "copilot",
    "ollama",
    "local",
    "openai",
    "claude",
    "anthropic",
    "gemini",
    "agent",
    "assistant",
    "qwen"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "silo-sidebar",
          "title": "Silo",
          "icon": "media/silo-icon.svg"
        }
      ]
    },
    "views": {
      "silo-sidebar": [
        {
          "type": "webview",
          "id": "silo.chatView",
          "name": "Silo"
        }
      ]
    },
    "commands": [
      {
        "command": "silo.openChat",
        "title": "Silo: Open Chat",
        "icon": { "light": "media/silologonobg.svg", "dark": "media/silologonobg.svg" }
      },
      { "command": "silo.analyzeFile", "title": "Silo: Analyze Current File" },
      { "command": "silo.refactorSelection", "title": "Silo: Refactor Selection" },
      { "command": "silo.explainSelection", "title": "Silo: Explain Selection" }
    ],
    "menus": {
      "editor/title": [
        { "command": "silo.openChat", "group": "navigation@1" }
      ],
      "editor/context": [
        { "command": "silo.refactorSelection", "when": "editorHasSelection", "group": "silo" },
        { "command": "silo.explainSelection", "when": "editorHasSelection", "group": "silo" }
      ]
    },
    "configuration": {
      "title": "Silo",
      "properties": {
        "silo.backendUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8942",
          "description": "Silo backend URL"
        },
        "silo.contextFiles": {
          "type": "number",
          "default": 5,
          "description": "Number of open files to include in context"
        },
        "silo.backendPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Silo backend directory (folder containing main.py). Leave empty to auto-detect."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.26.0"
  }
}
